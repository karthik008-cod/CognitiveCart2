{
  "version": 2,
  "builds": [
    {
      "src": "api/vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/vercel.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/vercel.js"
    }
  ],
  "crons": [
    {
      "path": "/api/check-prices",
      "schedule": "0 0 * * *"
    }
  ]
}